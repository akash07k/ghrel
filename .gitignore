# PyInstaller artifacts (build/dist are output; the spec file is hand-crafted
# and tracked — un-ignore ghrel.spec specifically).
*.spec
!ghrel.spec
build/
dist/

# Per-run logs (may contain repo URLs and asset names; gitignored to prevent leak)
logs/

# Downloaded release assets
downloads/

# Local config (may contain a GitHub PAT)
config.toml

# IDE / editor noise
.vscode/
.idea/
*.swp
*~
.DS_Store
Thumbs.db
desktop.ini

# Beads / Dolt files (added by bd init)
.dolt/
*.db
